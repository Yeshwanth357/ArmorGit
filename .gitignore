# Root .gitignore for ArmorGit (Python backend + React/Vite frontend)

# Dependency directories
node_modules/
jspm_packages/
web_drivers/

# Build outputs and distribution directories
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.cache/

# Python cache & compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/
.dmypy.json
dmypy.json

# Local environment variables & secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and databases
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.db
*.sqlite

# IDEs/Editors configuration
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Diagnostic/temporary folders
tmp/
temp/
.agents/
.gemini/
